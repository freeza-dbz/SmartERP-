generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LedgerType {
  CUSTOMER
  SUPPLIER
  BANK
  CASH
  ASSET
  LIABILITY
  INCOME
  EXPENSE
}

model Company {
  id               Int               @id @default(autoincrement())
  userId           Int
  name             String            @db.VarChar(255)
  address          String?
  gstNumber        String?           @db.VarChar(20)
  state            String?           @db.VarChar(100)
  financialYear    String            @db.VarChar(20)
  createdAt        DateTime?         @default(now()) @db.Timestamp(6)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ledgers          Ledger[]
  purchaseVouchers PurchaseVoucher[]
  salesVouchers    SalesVoucher[]
  stockGroups      StockGroup[]
  stockItems       StockItem[]
  units            Unit[]
}

model Ledger {
  id                         Int               @id @default(autoincrement())
  name                       String
  type                       LedgerType
  openingBalance             Decimal           @default(0) @db.Decimal(12, 2)
  currentBalance             Decimal           @default(0) @db.Decimal(12, 2)
  isSystem                   Boolean           @default(false)
  companyId                  Int
  company                    Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseVouchersAsSupplier PurchaseVoucher[] @relation("SupplierPurchases")
  salesVouchersAsCustomer    SalesVoucher[]    @relation("CustomerSales")
}

model PurchaseItem {
  id                Int             @id @default(autoincrement())
  purchaseVoucherId Int
  itemId            Int
  quantity          Decimal?        @db.Decimal(12, 2)
  rate              Decimal?        @db.Decimal(12, 2)
  amount            Decimal?        @db.Decimal(12, 2)
  stockItem         StockItem       @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchaseVoucher   PurchaseVoucher @relation(fields: [purchaseVoucherId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model PurchaseVoucher {
  id            Int            @id @default(autoincrement())
  companyId     Int
  supplierId    Int
  voucherNo     String?        @db.VarChar(50)
  voucherDate   DateTime?      @db.Date
  totalAmount   Decimal?       @db.Decimal(12, 2)
  purchaseItems PurchaseItem[]
  company       Company        @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supplier      Ledger         @relation("SupplierPurchases", fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model SalesItem {
  id             Int          @id @default(autoincrement())
  salesVoucherId Int
  itemId         Int
  quantity       Decimal?     @db.Decimal(12, 2)
  rate           Decimal?     @db.Decimal(12, 2)
  amount         Decimal?     @db.Decimal(12, 2)
  stockItem      StockItem    @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  salesVoucher   SalesVoucher @relation(fields: [salesVoucherId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model SalesVoucher {
  id          Int         @id @default(autoincrement())
  companyId   Int
  customerId  Int
  invoiceNo   String?     @db.VarChar(50)
  invoiceDate DateTime?   @db.Date
  totalAmount Decimal?    @db.Decimal(12, 2)
  salesItems  SalesItem[]
  company     Company     @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer    Ledger      @relation("CustomerSales", fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model StockGroup {
  id         Int          @id @default(autoincrement())
  name       String
  parentId   Int?
  parent     StockGroup?  @relation("GroupToParent", fields: [parentId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  children   StockGroup[] @relation("GroupToParent")
  companyId  Int
  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockItems StockItem[]
}

model StockItem {
  id            Int            @id @default(autoincrement())
  companyId     Int
  name          String
  sku           String?        @db.VarChar(100)
  purchasePrice Decimal        @default(0) @db.Decimal(12, 2)
  sellingPrice  Decimal        @default(0) @db.Decimal(12, 2)
  gstRate       Int            @default(0) // Store as a whole number, e.g., 18 for 18%
  openingStock  Decimal        @default(0) @db.Decimal(12, 2)
  currentStock  Decimal        @default(0) @db.Decimal(12, 2)
  unitId        Int
  unit          Unit           @relation(fields: [unitId], references: [id])
  groupId       Int
  stockGroup    StockGroup     @relation(fields: [groupId], references: [id])
  purchaseItems PurchaseItem[]
  salesItems    SalesItem[]
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Unit {
  id         Int         @id @default(autoincrement())
  companyId  Int
  name       String // e.g., "Pieces"
  shortName  String // e.g., "PCS"
  stockItems StockItem[]
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model User {
  id        Int       @id @default(autoincrement())
  fullName  String    @db.VarChar(100)
  email     String    @unique @db.VarChar(255)
  password  String    @db.VarChar(255)
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  updatedAt DateTime? @default(now()) @db.Timestamp(6)
  username  String?
  companies Company[]
}
