generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model companies {
  id                Int                 @id @default(autoincrement())
  user_id           Int
  company_name      String              @db.VarChar(255)
  address           String?
  gst_number        String?             @db.VarChar(20)
  state             String?             @db.VarChar(100)
  financial_year    String?             @db.VarChar(20)
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  users             users               @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_company_user")
  customers         customers[]
  purchase_vouchers purchase_vouchers[]
  sales_vouchers    sales_vouchers[]
  stock_groups      stock_groups[]
  stock_items       stock_items[]
  suppliers         suppliers[]
  units             units[]
}

model customers {
  id              Int              @id @default(autoincrement())
  company_id      Int
  customer_name   String           @db.VarChar(255)
  mobile          String?          @db.VarChar(20)
  address         String?
  gst_number      String?          @db.VarChar(20)
  opening_balance Decimal?         @default(0) @db.Decimal(12, 2)
  created_at      DateTime?        @default(now()) @db.Timestamp(6)
  companies       companies        @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales_vouchers  sales_vouchers[]
}

model purchase_items {
  id                  Int               @id @default(autoincrement())
  purchase_voucher_id Int
  item_id             Int
  quantity            Decimal?          @db.Decimal(12, 2)
  rate                Decimal?          @db.Decimal(12, 2)
  amount              Decimal?          @db.Decimal(12, 2)
  stock_items         stock_items       @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchase_vouchers   purchase_vouchers @relation(fields: [purchase_voucher_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model purchase_vouchers {
  id             Int              @id @default(autoincrement())
  company_id     Int
  supplier_id    Int
  voucher_no     String?          @db.VarChar(50)
  voucher_date   DateTime?        @db.Date
  total_amount   Decimal?         @db.Decimal(12, 2)
  purchase_items purchase_items[]
  companies      companies        @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  suppliers      suppliers        @relation(fields: [supplier_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model sales_items {
  id               Int            @id @default(autoincrement())
  sales_voucher_id Int
  item_id          Int
  quantity         Decimal?       @db.Decimal(12, 2)
  rate             Decimal?       @db.Decimal(12, 2)
  amount           Decimal?       @db.Decimal(12, 2)
  stock_items      stock_items    @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales_vouchers   sales_vouchers @relation(fields: [sales_voucher_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model sales_vouchers {
  id           Int           @id @default(autoincrement())
  company_id   Int
  customer_id  Int
  invoice_no   String?       @db.VarChar(50)
  invoice_date DateTime?     @db.Date
  total_amount Decimal?      @db.Decimal(12, 2)
  sales_items  sales_items[]
  companies    companies     @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customers    customers     @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model stock_groups {
  id          Int           @id @default(autoincrement())
  company_id  Int
  group_name  String        @db.VarChar(100)
  companies   companies     @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  stock_items stock_items[]
}

model stock_items {
  id             Int              @id @default(autoincrement())
  company_id     Int
  group_id       Int?
  unit_id        Int?
  item_name      String           @db.VarChar(255)
  sku            String?          @db.VarChar(100)
  purchase_price Decimal?         @db.Decimal(12, 2)
  selling_price  Decimal?         @db.Decimal(12, 2)
  gst_percent    Decimal?         @db.Decimal(5, 2)
  opening_stock  Decimal?         @default(0) @db.Decimal(12, 2)
  current_stock  Decimal?         @default(0) @db.Decimal(12, 2)
  purchase_items purchase_items[]
  sales_items    sales_items[]
  companies      companies        @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  stock_groups   stock_groups?    @relation(fields: [group_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  units          units?           @relation(fields: [unit_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model suppliers {
  id                Int                 @id @default(autoincrement())
  company_id        Int
  supplier_name     String              @db.VarChar(255)
  mobile            String?             @db.VarChar(20)
  address           String?
  gst_number        String?             @db.VarChar(20)
  opening_balance   Decimal?            @default(0) @db.Decimal(12, 2)
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  purchase_vouchers purchase_vouchers[]
  companies         companies           @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model units {
  id          Int           @id @default(autoincrement())
  company_id  Int
  unit_name   String        @db.VarChar(20)
  stock_items stock_items[]
  companies   companies     @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model users {
  id         Int         @id @default(autoincrement())
  name       String      @db.VarChar(100)
  email      String      @unique @db.VarChar(255)
  password   String      @db.VarChar(255)
  created_at DateTime?   @default(now()) @db.Timestamp(6)
  updated_at DateTime?   @default(now()) @db.Timestamp(6)
  companies  companies[]
}
